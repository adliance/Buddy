@page
@{
    ViewData["Title"] = "Notifications";
}

<agk-title text="Notifications">
    <code>agk-notification</code> renders an alert box for one of four levels, with an automatic icon.
</agk-title>

<section>
    <agk-notification level="Info">This is an info notification.</agk-notification>
    <agk-notification level="Success">This is a success notification.</agk-notification>
    <agk-notification level="Warning">This is a warning notification.</agk-notification>
    <agk-notification level="Error">This is an error notification.</agk-notification>
</section>
