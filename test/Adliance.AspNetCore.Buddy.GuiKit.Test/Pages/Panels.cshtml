@page
@model Adliance.AspNetCore.Buddy.GuiKit.Test.Pages.PanelsModel
@{
    ViewData["Title"] = "Panels";
}

<agk-title text="Panels">
    <code>agk-panel</code> renders an <code>&lt;article&gt;</code> panel, optionally with a title, icon,
    and collapsible or htmx-loaded content.
</agk-title>

<section>
    <agk-panel title="Simple Panel" icon="fa-circle-info">
        <p>A plain panel with a title and an icon.</p>
    </agk-panel>
    <agk-panel title="Collapsible Panel (open)" icon="fa-square-caret-down" collapsible="Opened">
        <p>Click the toggle button to collapse this panel.</p>
    </agk-panel>
    <agk-panel title="Collapsible Panel (closed)" icon="fa-square-caret-right" collapsible="Closed">
        <p>Click the toggle button to expand this panel.</p>
    </agk-panel>
    <agk-panel title="Loaded via htmx" icon="fa-bolt" hx-get="/Panels?handler=Snippet">
        <p><em>Static fallback content, rendered below the htmx-loaded content.</em></p>
    </agk-panel>
</section>
