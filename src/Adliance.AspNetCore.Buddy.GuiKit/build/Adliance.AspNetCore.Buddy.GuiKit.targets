<Project>
  <!--
  These properties default to the packed NuGet layout (build/lib/...) next to this file. A project that
  references the GuiKit source directly (via ProjectReference instead of PackageReference) can import this
  file and override the properties beforehand to point at the source folders instead, reusing this same
  copy logic without duplicating it.
  -->
  <PropertyGroup>
    <GuiKitCssFile Condition="'$(GuiKitCssFile)' == ''">$(MSBuildThisFileDirectory)lib/min.css</GuiKitCssFile>
    <GuiKitJsFile Condition="'$(GuiKitJsFile)' == ''">$(MSBuildThisFileDirectory)lib/min.js</GuiKitJsFile>
    <GuiKitFontAwesomeDir Condition="'$(GuiKitFontAwesomeDir)' == ''">$(MSBuildThisFileDirectory)lib/fontawesome/</GuiKitFontAwesomeDir>
    <GuiKitFontsDir Condition="'$(GuiKitFontsDir)' == ''">$(MSBuildThisFileDirectory)lib/fonts/</GuiKitFontsDir>
    <GuiKitThemesDir Condition="'$(GuiKitThemesDir)' == ''">$(MSBuildThisFileDirectory)lib/themes/</GuiKitThemesDir>
  </PropertyGroup>

  <Target Name="CopyGuiKitStaticFiles" BeforeTargets="Build">
    <ItemGroup>
      <_FontAwesomeFiles Include="$(GuiKitFontAwesomeDir)**/*"/>
      <_FontFiles Include="$(GuiKitFontsDir)**/*"/>
      <_ThemeFiles Include="$(GuiKitThemesDir)**/*"/>
    </ItemGroup>

    <MakeDir Directories="$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit"/>
    <Copy SourceFiles="$(GuiKitCssFile)"
          DestinationFolder="$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/"
          SkipUnchangedFiles="true"/>
    <Copy SourceFiles="$(GuiKitJsFile)"
          DestinationFolder="$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/"
          SkipUnchangedFiles="true"/>

    <MakeDir Directories="@(_FontAwesomeFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/fontawesome/%(RecursiveDir)')"/>
    <Copy SourceFiles="@(_FontAwesomeFiles)"
          DestinationFiles="@(_FontAwesomeFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/fontawesome/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"/>

    <MakeDir Directories="@(_FontFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/fonts/%(RecursiveDir)')"/>
    <Copy SourceFiles="@(_FontFiles)"
          DestinationFiles="@(_FontFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/fonts/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"/>

    <MakeDir Directories="@(_ThemeFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/themes/%(RecursiveDir)')"/>
    <Copy SourceFiles="@(_ThemeFiles)"
          DestinationFiles="@(_ThemeFiles->'$(MSBuildProjectDirectory)/wwwroot/lib/adliance.guikit/themes/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"/>
  </Target>
</Project>
